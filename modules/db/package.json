{
  "name": "@chatondearu/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check:migrations": "tsx scripts/check-migrations-structure.ts",
    "db:seed:dev": "tsx src/seed/dev.ts",
    "db:import:sql": "tsx scripts/import-firestore.ts"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@chatondearu/eslint-config": "workspace:*",
    "@types/node": "latest",
    "@types/pg": "latest",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
