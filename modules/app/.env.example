# Career page + PDF — copy to `.env` and fill (`.env` is gitignored).
# These keys are exposed to the browser (NUXT_PUBLIC_*); do not use for truly secret values.

# Database / Auth (server-side only)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chatondearu
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Canonical site URL (French domain); used by redirects and SEO.
NUXT_PUBLIC_SITE_URL=https://chatondearu.fr

# Optional: extra hostnames permanently redirect → site URL with /en when needed.
NUXT_PUBLIC_REDIRECT_HOSTS_EN=

NUXT_PUBLIC_ME_HOST=

NUXT_PUBLIC_CAREER_FULL_NAME=
NUXT_PUBLIC_CAREER_EMAIL=
NUXT_PUBLIC_CAREER_PHONE=
NUXT_PUBLIC_CAREER_LOCATION=

NUXT_PUBLIC_UMAMI_SCRIPT_URL=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
