# Career page + PDF — copy to `.env` and fill (`.env` is gitignored).
# These keys are exposed to the browser (NUXT_PUBLIC_*); do not use for truly secret values.

NUXT_PUBLIC_CAREER_FULL_NAME=
NUXT_PUBLIC_CAREER_EMAIL=
NUXT_PUBLIC_CAREER_PHONE=
NUXT_PUBLIC_CAREER_LOCATION=

# Umami analytics (public IDs; safe to expose in the browser)
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://umami.neomatix.net/script.js
NUXT_PUBLIC_UMAMI_WEBSITE_ID=98b09710-c803-4c10-979c-2b122c5e2e27
