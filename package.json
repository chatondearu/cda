{
  "name": "@chatondearu/workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.33.0 <11"
  },
  "scripts": {
    "dev": "pnpm --filter @chatondearu/app dev",
    "build": "pnpm --filter @chatondearu/app build",
    "generate": "pnpm --filter @chatondearu/app generate",
    "preview": "pnpm --filter @chatondearu/app preview",
    "postinstall": "pnpm --filter @chatondearu/app postinstall",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @chatondearu/app typecheck",
    "db:typecheck": "pnpm --filter @chatondearu/db typecheck",
    "db:generate": "pnpm --filter @chatondearu/db db:generate",
    "db:migrate": "pnpm --filter @chatondearu/db db:migrate",
    "db:check:migrations": "pnpm --filter @chatondearu/db db:check:migrations",
    "db:seed:dev": "pnpm --filter @chatondearu/db db:seed:dev",
    "db:import:sql": "pnpm --filter @chatondearu/db db:import:sql",
    "lint:fix": "pnpm -r lint:fix",
    "lint:colors": "pnpm --filter @chatondearu/design-system-nuxt lint:colors",
    "sync:archive:github": "node scripts/sync-github-archives.mjs"
  }
}
